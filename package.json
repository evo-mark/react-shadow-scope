{
	"name": "@evomark/react-shadow-scope",
	"version": "2.1.0",
	"description": "Brings Shadow DOM CSS encapsulation to React, along with a DSD-compatible template element.",
	"type": "module",
	"main": "./dist/index.cjs",
	"module": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"files": [
		"/dist",
		"/package.json",
		"/README.md",
		"/LICENSE"
	],
	"scripts": {
		"demo": "cd demo/react && rm -rf node_modules && npm i && npm start",
		"demo:next": "cd demo/next && rm -rf node_modules && npm i && npm start",
		"build": "tsup src/index.ts --format cjs,esm --dts --no-clean",
		"lint": "tsc --noEmit && eslint .",
		"test": "vitest",
		"coverage": "vitest run --coverage",
		"upgrade:react": "npm i react@latest react-dom@latest @types/react@latest @types/react-dom@latest -D",
		"prepublishOnly": "npm run build"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/evo-mark/react-shadow-scope.git"
	},
	"keywords": [
		"css",
		"scoped css",
		"css encapsulation",
		"encapsulated css",
		"shadow dom",
		"shadow dom encapsulation",
		"declarative shadow dom"
	],
	"contributors": [
		{
			"name": "Craig Riley",
			"email": "c.riley@evomark.co.uk",
			"url": "https://evomark.co.uk"
		},
		{
			"name": "Jonathan DeWitt"
		}
	],
	"license": "MIT",
	"bugs": {
		"url": "https://github.com/evo-mark/react-shadow-scope/issues"
	},
	"homepage": "https://github.com/evo-mark/react-shadow-scope#readme",
	"devDependencies": {
		"@eslint/eslintrc": "^3.3.5",
		"@eslint/js": "^10.0.1",
		"@testing-library/react": "^16.3.2",
		"@testing-library/user-event": "^14.6.1",
		"@types/react": "^19.2.17",
		"@types/react-dom": "^19.2.3",
		"@typescript-eslint/eslint-plugin": "^8.63.0",
		"@typescript-eslint/parser": "^8.63.0",
		"@vitejs/plugin-react": "^6.0.3",
		"@vitest/browser": "^4.1.10",
		"@vitest/coverage-istanbul": "^4.1.10",
		"@vitest/ui": "^4.1.10",
		"eslint": "^10.6.0",
		"express": "^4.22.2",
		"globals": "^17.7.0",
		"happy-dom": "^20.10.6",
		"jsdom": "^29.1.1",
		"playwright": "^1.61.1",
		"playwright-core": "^1.61.1",
		"prettier": "^3.9.4",
		"react": "^19.2.7",
		"react-dom": "^19.2.7",
		"tsup": "^8.5.1",
		"typescript": "^5.9.3",
		"vite": "^8.1.3",
		"vitest": "^4.1.10"
	},
	"peerDependencies": {
		"react": ">=18.0.0",
		"react-dom": ">=18.0.0"
	},
	"packageManager": "pnpm@11.10.0+sha512.0b7f8b98060031904c017e3a41eb187a16d40eeb829b95c4f8cb03681761fc4ab53dd219115b9b447f4dce1a05a214764461e7d3703392a9f32f9511ce8c86c8"
}
